{
  "business": {
    "name": "MARZARK Trading Intelligence",
    "offer": "Risk-first market brief with premium alert candidates",
    "price_usd_monthly": 29
  },
  "schedule": {
    "cron": "*/30 * * * *"
  },
  "trading": {
    "symbols": [
      "SPY",
      "QQQ",
      "IWM",
      "DIA"
    ],
    "min_price_move_pct_alert": 0.5,
    "risk_filters": {
      "max_alerts_per_cycle": 2,
      "max_abs_move_pct": 6,
      "min_volume": 0,
      "max_quote_age_minutes": 720,
      "symbol_cooldown_minutes": 120,
      "prefer_high_volume": true
    }
  },
  "updates": {
    "send_on_no_change": false,
    "max_telegram_chars": 3500,
    "max_discord_chars": 1800
  },
  "premium_reports": {
    "write_on_no_change": true,
    "history_max_entries": 1000
  },
  "policy": {
    "allow_external_apis_with_secret_only": true,
    "market_data_provider": "databento",
    "market_data_secret": "DATABENTO_API_KEY",
    "databento_dataset": "DBEQ.BASIC",
    "databento_schema": "ohlcv-1m",
    "databento_lookback_minutes": 180,
    "databento_stype_in": "raw_symbol",
    "databento_stype_out": "instrument_id",
    "telegram_secrets": [
      "TELEGRAM_BOT_TOKEN",
      "TELEGRAM_CHAT_ID"
    ],
    "discord_secret": "DISCORD_WEBHOOK_URL"
  }
}
